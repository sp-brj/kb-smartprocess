# --- База данных (Supabase Postgres) ---
# Получить в Supabase: Project Settings → Database → Connection string (Pooler, mode=session или transaction)
DATABASE_URL="postgresql://postgres.xxx:PASSWORD@aws-0-xxx.pooler.supabase.com:6543/postgres?pgbouncer=true"

# --- NextAuth ---
# Сгенерировать: openssl rand -base64 32
NEXTAUTH_SECRET=""
# Для локалки:
NEXTAUTH_URL="http://localhost:3000"

# --- Cloudinary (загрузка изображений) ---
# Получить: cloudinary.com → Dashboard
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""

# --- AI-чат (RAG-поиск через OpenAI) ---
# Embeddings: text-embedding-3-small (1536 dim), генерация: gpt-4o-mini
# Получить ключ: https://platform.openai.com/api-keys
OPENAI_API_KEY=""

# --- Vercel (опционально, для деплоя) ---
VERCEL_OIDC_TOKEN=""
