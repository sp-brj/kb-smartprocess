# Скопируй в .env и заполни. Реальный .env в git НЕ коммитится (см. .gitignore).
# Ключ создаётся в UI KB: kb.smartprocess.ru → Профиль → API Keys.
# Для MCP создаётся отдельный ключ с правами read/write — не переиспользуй личный ключ.

KB_URL=https://kb.smartprocess.ru
KB_API_KEY=kb_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
MCP_PORT=8014
